{
  "name": "Let's Copy",
  "version": "2.1.0",
  "manifest_version": 3,
  "description": "Unlock copy, text selection, and right-click on websites that disable them.",
  "homepage_url": "https://github.com/NatLee/lets-copy",
  "icons": {
    "24": "icons/icon24.png",
    "32": "icons/icon32.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "24": "icons/icon24-disable.png",
      "32": "icons/icon32-disable.png",
      "128": "icons/icon128-disable.png"
    },
    "default_title": "Let's Copy",
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-current-site": {
      "suggested_key": {
        "default": "Alt+Shift+C"
      },
      "description": "Toggle Let's Copy for the current site"
    }
  }
}
